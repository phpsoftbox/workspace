# Docker Compose
COMPOSE_PROJECT_NAME=phpsoftbox-workspace

# Docker paths
BACKEND_PATH=./local/backend

# Used only by the separate "frontend" profile.
# If frontend lives inside BACKEND_PATH, keep the "frontend" profile disabled.
FRONTEND_PATH=./local/frontend

# Docker user
USER_NAME=dev
USER_ID=1000
GROUP_ID=1000

# Docker build
PHP_FPM_IMAGE=php:8.5-fpm
NODE_MAJOR=22
XDEBUG_VERSION=3.5.0

# Docker runtime
PHP_IDE_CONFIG=serverName=backend
XDEBUG_MODE=debug,develop
VITE_DEV_SERVER=http://localhost:5173
QUEUE_COMMAND=php psb queue:listen
SCHEDULER_COMMAND=php psb schedule:work
WEBSOCKET_COMMAND=php psb pushr:serve --host=0.0.0.0 --port=8080 --app-id=app-1 --secret=secret-1
TG_BOT_POLLING_COMMAND=php psb telegram:poll

# Docker ports
NGINX_HTTP_PORT=8080
VITE_PORT=5173
WEBSOCKET_PORT=8081
MARIADB_PORT=13306
POSTGRES_PORT=15432
MONGODB_PORT=27017
REDIS_PORT=16379
MEMCACHED_PORT=11211
MAILPIT_SMTP_PORT=1025
MAILPIT_HTTP_PORT=8025
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
GOTENBERG_PORT=13000

# Docker service images
MARIADB_IMAGE=mariadb:11.8
POSTGRES_IMAGE=postgres:17-alpine
MONGODB_IMAGE=mongo:8
REDIS_IMAGE=redis:7-alpine
MEMCACHED_IMAGE=memcached:1.6-alpine
MAILPIT_IMAGE=axllent/mailpit:latest
MINIO_IMAGE=minio/minio:latest
MINIO_MC_IMAGE=minio/mc:latest
GOTENBERG_IMAGE=gotenberg/gotenberg:8

# Docker service credentials
MARIADB_DATABASE=app
MARIADB_USER=app
MARIADB_PASSWORD=app
MARIADB_ROOT_PASSWORD=root

POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app

MONGO_INITDB_ROOT_USERNAME=app
MONGO_INITDB_ROOT_PASSWORD=app

MINIO_ROOT_USER=app
MINIO_ROOT_PASSWORD=app-password
MINIO_BUCKET=app

# Application environment
APP_ENV=dev
APP_DEBUG=1
APP_URL=http://localhost:8080
APP_KEY=
APP_INFLECTOR_LANG=en

APP_DB_MAIN_DSN=mariadb://app:app@mariadb:3306/app
APP_DB_SEARCH_DSN=postgres://app:app@postgres:5432/app
APP_DB_MIGRATIONS_BASE=database/migrations
APP_MONGO_URI=mongodb://app:app@mongodb:27017/?authSource=admin

APP_STORAGE_DISK=local
APP_STORAGE_URL=/storage

PUSHR_APP_ID=app-1
PUSHR_SECRET=secret-1
PUSHR_PUBLIC_URL=ws://localhost:8081

# Cookie Secure policy: "always", "never", or "auto".
# Workspace uses "auto" so local http://localhost works; use "always" for HTTPS environments.
APP_SESSION_SECURE=auto
APP_SESSION_DOMAIN=
